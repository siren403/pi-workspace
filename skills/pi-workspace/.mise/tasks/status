#!/usr/bin/env sh
#MISE description="Inspect pi-workspace skill install and target workspace state"
set -eu

if ! command -v bun >/dev/null 2>&1; then
  cat >&2 <<EOF
[status] ERROR: bun is required before pi-workspace tasks can run.

This skill ships Bun/TypeScript mise tasks. From the skill directory, run:

  mise trust --yes
  mise install bun

Then retry:

  mise run status -- --target <path> --intent "<request>"
EOF
  exit 1
fi

exec bun "$MISE_CONFIG_ROOT/.mise/tasks/lib/status-main.ts" "$@"
