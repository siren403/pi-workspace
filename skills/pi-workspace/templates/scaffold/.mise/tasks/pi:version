#!/bin/sh
#MISE description="sandbox pi 버전 변경. mise.toml 핀 + mise lock + .yolobox.Dockerfile 동기화. 예: mise run pi:version -- 0.75.0"
VERSION=${1:?Usage: mise run pi:version -- <x.y.z>}
case "$VERSION" in
  *[!0-9A-Za-z._+-]*)
    echo "[pi:version] invalid version: $VERSION" >&2
    exit 2
    ;;
esac
sed -i "s/\\(\"npm:@earendil-works\\/pi-coding-agent\" = \\)\"[^\"]*\"/\\1\"${VERSION}\"/" .mise.toml
mise lock
PI_VERSION=$(grep -A2 'pi-coding-agent' mise.lock | grep '^version' | sed 's/version = "\(.*\)"/\1/')
cat > .yolobox.Dockerfile << EOF
USER root
ENV PI_WORKSPACE_SANDBOX=1
ENV MISE_INSTALL_PATH=/usr/local/bin/mise
RUN npm install -g --prefix /usr/local @jdxcode/mise
RUN NPM_CONFIG_BEFORE= NPM_CONFIG_MIN_RELEASE_AGE=0 npm install -g --prefix /usr/local @earendil-works/pi-coding-agent@${PI_VERSION}

# PI_AUTORUN_CMD가 있으면 bash 시작 직후 해당 pi 명령을 exec
RUN echo 'if [ -n "\$PI_AUTORUN_CMD" ]; then exec sh -lc "\$PI_AUTORUN_CMD"; elif [ -n "\$PI_AUTORUN" ]; then exec pi; fi' >> /etc/bash.bashrc

USER yolo
EOF
echo "[pi:version] Updated → @earendil-works/pi-coding-agent@${PI_VERSION}"
echo "             mise.lock and .yolobox.Dockerfile synced. Commit both files."
