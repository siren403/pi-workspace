#!/bin/sh
#MISE description="pi를 YoloBox 샌드박스에서 실행. mise.lock 기반으로 .yolobox.Dockerfile 자동 동기화"

# --pi-version 플래그 파싱 (일회성 오버라이드).
# 호환성을 위해 값이 딸린 --version도 오버라이드로 처리하고, 단독 --version은 pi CLI로 전달한다.
# 그 외 인자는 pi CLI로 전달한다. 예: mise run pi -- -c
PI_VERSION=""
PI_ARGS=""
cleanup_yolobox_images() {
  echo "[pi] sandbox exited; checking old yolobox-custom images..."

  if ! command -v docker >/dev/null 2>&1; then
    echo "[pi] image cleanup skipped: docker command not found"
    return
  fi

  images=$(docker image ls --format "{{.ID}} {{.Repository}}:{{.Tag}}" --filter "reference=yolobox-custom:*" 2>/dev/null || true)
  image_count=$(printf '%s\n' "$images" | sed '/^$/d' | wc -l | tr -d ' ')

  if [ "$image_count" -le 1 ]; then
    echo "[pi] image cleanup: nothing to remove (${image_count} yolobox-custom image(s))"
    return
  fi

  remove_ids=$(printf '%s\n' "$images" | sed '/^$/d' | awk 'NR > 1 {print $1}')
  remove_names=$(printf '%s\n' "$images" | sed '/^$/d' | awk 'NR > 1 {$1=""; sub(/^ /, ""); print}')
  remove_count=$(printf '%s\n' "$remove_ids" | sed '/^$/d' | wc -l | tr -d ' ')

  echo "[pi] image cleanup triggered: removing ${remove_count} old yolobox-custom image(s), keeping newest"
  printf '%s\n' "$remove_names" | sed 's/^/[pi]   remove: /'

  cleanup_output=$(docker image rm $remove_ids 2>&1)
  cleanup_status=$?
  if [ "$cleanup_status" -eq 0 ]; then
    echo "[pi] image cleanup complete: removed ${remove_count} image(s)"
  else
    echo "[pi] image cleanup warning: docker image rm exited ${cleanup_status}"
    printf '%s\n' "$cleanup_output" | sed 's/^/[pi]   /'
  fi
}
quote_arg() {
  # POSIX-safe single-quote escaping for sh -lc in the sandbox.
  printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}
while [ $# -gt 0 ]; do
  case "$1" in
    --pi-version)
      PI_VERSION="${2:?Usage: mise run pi -- --pi-version <x.y.z>}"
      shift 2
      ;;
    --version)
      if [ $# -ge 2 ]; then
        PI_VERSION="$2"
        shift 2
      else
        PI_ARGS="${PI_ARGS}${PI_ARGS:+ }$(quote_arg "$1")"
        shift
      fi
      ;;
    --)
      shift
      while [ $# -gt 0 ]; do
        PI_ARGS="${PI_ARGS}${PI_ARGS:+ }$(quote_arg "$1")"
        shift
      done
      ;;
    *)
      PI_ARGS="${PI_ARGS}${PI_ARGS:+ }$(quote_arg "$1")"
      shift
      ;;
  esac
done

# 버전 미지정 시 mise.lock에서 추출
if [ -z "$PI_VERSION" ] && [ -f mise.lock ]; then
  PI_VERSION=$(grep -A2 'pi-coding-agent' mise.lock | grep '^version' | sed 's/version = "\(.*\)"/\1/')
fi

# .yolobox.Dockerfile 동기화
if [ -n "$PI_VERSION" ]; then
  case "$PI_VERSION" in
    *[!0-9A-Za-z._+-]*)
      echo "[pi] invalid --version: $PI_VERSION" >&2
      exit 2
      ;;
  esac
  cat > .yolobox.Dockerfile << EOF
USER root
ENV PI_WORKSPACE_SANDBOX=1
ENV MISE_INSTALL_PATH=/usr/local/bin/mise
RUN npm install -g --prefix /usr/local @jdxcode/mise
RUN npm install -g --prefix /usr/local @earendil-works/pi-coding-agent@${PI_VERSION}
RUN echo 'if [ -n "\$PI_AUTORUN_CMD" ]; then exec sh -lc "\$PI_AUTORUN_CMD"; elif [ -n "\$PI_AUTORUN" ]; then exec pi; fi' >> /etc/bash.bashrc
USER yolo
EOF
fi

NPM_GLOBAL_ROOT=$(mise exec -- npm root -g 2>/dev/null || npm root -g)
PI_AUTORUN_CMD="pi${PI_ARGS:+ $PI_ARGS}"

yolobox \
  --mount "$HOME/.pi/agent:/home/yolo/.pi/agent" \
  --mount "$NPM_GLOBAL_ROOT:/home/yolo/.npm-global/lib/node_modules" \
  --env NPM_CONFIG_PREFIX=/home/yolo/.npm-global \
  --env PI_AUTORUN_CMD="$PI_AUTORUN_CMD"
sandbox_status=$?

cleanup_yolobox_images
exit "$sandbox_status"
