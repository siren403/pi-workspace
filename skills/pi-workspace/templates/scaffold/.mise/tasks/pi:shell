#!/bin/sh
#MISE description="pi 명령어 비대화형 실행 — 검증/CI용 (예: mise run agent-shell -- list)"
cleanup_yolobox_images() {
  echo "[pi:shell] sandbox exited; checking old yolobox-custom images..."

  if ! command -v docker >/dev/null 2>&1; then
    echo "[pi:shell] image cleanup skipped: docker command not found"
    return
  fi

  images=$(docker image ls --format "{{.ID}} {{.Repository}}:{{.Tag}}" --filter "reference=yolobox-custom:*" 2>/dev/null || true)
  image_count=$(printf '%s\n' "$images" | sed '/^$/d' | wc -l | tr -d ' ')

  if [ "$image_count" -le 1 ]; then
    echo "[pi:shell] image cleanup: nothing to remove (${image_count} yolobox-custom image(s))"
    return
  fi

  remove_ids=$(printf '%s\n' "$images" | sed '/^$/d' | awk 'NR > 1 {print $1}')
  remove_names=$(printf '%s\n' "$images" | sed '/^$/d' | awk 'NR > 1 {$1=""; sub(/^ /, ""); print}')
  remove_count=$(printf '%s\n' "$remove_ids" | sed '/^$/d' | wc -l | tr -d ' ')

  echo "[pi:shell] image cleanup triggered: removing ${remove_count} old yolobox-custom image(s), keeping newest"
  printf '%s\n' "$remove_names" | sed 's/^/[pi:shell]   remove: /'

  cleanup_output=$(printf '%s\n' "$remove_names" | xargs docker image rm 2>&1)
  cleanup_status=$?
  if [ "$cleanup_status" -eq 0 ]; then
    echo "[pi:shell] image cleanup complete: removed ${remove_count} image(s)"
  else
    echo "[pi:shell] image cleanup warning: docker image rm exited ${cleanup_status}"
    printf '%s\n' "$cleanup_output" | sed 's/^/[pi:shell]   /'
  fi
}

NPM_GLOBAL_ROOT=$(mise exec -- npm root -g 2>/dev/null || npm root -g)

yolobox run \
  --mount "$HOME/.pi/agent:/home/yolo/.pi/agent" \
  --mount "$NPM_GLOBAL_ROOT:/home/yolo/.npm-global/lib/node_modules" \
  --env NPM_CONFIG_PREFIX=/home/yolo/.npm-global \
  pi "$@"
sandbox_status=$?

cleanup_yolobox_images
exit "$sandbox_status"
